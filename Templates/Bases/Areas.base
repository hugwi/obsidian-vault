filters:
  and:
    - categories.contains(link("Areas"))
    - '!file.name.contains("Template")'
properties:
  file.name:
    displayName: Note
  domain:
    displayName: Domain
  created:
    displayName: Created
views:
  - type: table
    name: Areas
    groupBy:
      property: domain
      direction: ASC
    order:
      - file.name
      - domain
      - created
